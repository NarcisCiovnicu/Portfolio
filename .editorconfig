# Rules
root=true

# C# files formatting	===============================
[*.cs]

# Private readonly fields must use _ prefix
dotnet_naming_style.private_readonly_style.capitalization = camel_case
dotnet_naming_style.private_readonly_style.required_prefix = _
dotnet_naming_symbols.private_readonly_symbols.applicable_kinds = field
dotnet_naming_symbols.private_readonly_symbols.applicable_accessibilities = private
dotnet_naming_symbols.private_readonly_symbols.required_modifiers = readonly
dotnet_naming_rule.private_readonly_fields_should_have_prefix.symbols = private_readonly_symbols
dotnet_naming_rule.private_readonly_fields_should_have_prefix.style = private_readonly_style
dotnet_naming_rule.private_readonly_fields_should_have_prefix.severity = warning

# Private const fields must be uppercase with _ separator
dotnet_naming_style.uppercase_style.capitalization = all_upper
dotnet_naming_style.uppercase_style.word_separator = _
dotnet_naming_symbols.private_constants.applicable_kinds = field
dotnet_naming_symbols.private_constants.applicable_accessibilities = private
dotnet_naming_symbols.private_constants.required_modifiers = const
dotnet_naming_rule.private_constants_should_be_uppercase.symbols = private_constants
dotnet_naming_rule.private_constants_should_be_uppercase.style = uppercase_style
dotnet_naming_rule.private_constants_should_be_uppercase.severity = warning

# File-scoped namespaces
csharp_style_namespace_declarations = file_scoped:warning

# Require primary constructors for classes and structs
csharp_style_require_primary_constructors = true:warning

# ------------------------------

# JSON files formatting		===============================
[*.json]
indent_style = space
indent_size = 2

# ------------------------------

# CSPROJ files formatting	===============================
[*.csproj]
indent_style = space
indent_size = 2
